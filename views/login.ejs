<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EcoDrop - Autentikasi</title>
    <!-- Memanggil CSS Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { 
            background: linear-gradient(135deg, #e0f2f1, #80cbc4); 
            min-height: 100vh; 
            display: flex; 
            align-items: center; 
        }
        .card { 
            border-radius: 15px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.1); 
            border: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card p-4">
                    <h3 class="text-center text-success mb-4">🍃 EcoDrop</h3>
                    
                    <!-- Tempat untuk menampilkan pesan error nantinya -->
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger"><%= error %></div>
                    <% } %>

                    <!-- Navigasi Tab -->
                    <ul class="nav nav-tabs mb-3" id="myTab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active text-success" data-bs-toggle="tab" data-bs-target="#loginTab" type="button">Login</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link text-secondary" data-bs-toggle="tab" data-bs-target="#registerTab" type="button">Daftar</button>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <!-- Form Login -->
                        <div class="tab-pane fade show active" id="loginTab">
                            <form action="/login" method="POST">
                                <!-- Wajib: Token CSRF untuk Proteksi -->
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                
                                <div class="mb-3">
                                    <label class="form-label">Username</label>
                                    <input type="text" name="username" class="form-control" placeholder="Masukkan username" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Password</label>
                                    <input type="password" name="password" class="form-control" placeholder="Masukkan password" required>
                                </div>
                                <button type="submit" class="btn btn-success w-100">Masuk</button>
                            </form>
                        </div>

                        <!-- Form Register -->
                        <div class="tab-pane fade" id="registerTab">
                            <form action="/register" method="POST">
                                <!-- Wajib: Token CSRF untuk Proteksi -->
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                
                                <div class="mb-3">
                                    <label class="form-label">Username Baru</label>
                                    <input type="text" name="username" class="form-control" placeholder="Pilih username" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Password</label>
                                    <input type="password" name="password" class="form-control" placeholder="Buat password" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Peran (Role)</label>
                                    <select name="role" class="form-select">
                                        <option value="warga">Warga</option>
                                        <option value="petugas">Petugas Kebersihan</option>
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-outline-success w-100">Daftar Sekarang</button>
                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
    
    <!-- Memanggil JS Bootstrap untuk animasi Tab -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>